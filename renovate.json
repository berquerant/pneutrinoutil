{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranches": [
    "main"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "mysql",
      "description": "Manage mysql version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "MYSQL_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "redis",
      "description": "Manage redis version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "REDIS_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/minio/minio",
      "description": "Manage minio version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "MINIO_VERSION=(?<currentValue>RELEASE\\..+Z)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint",
      "description": "Manage golangci-lint version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "GOLANGCI_LINT_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "fe3dback/go-arch-lint",
      "description": "Manage go-arch-lint version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "GO_ARCH_LINT_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "koalaman/shellcheck",
      "description": "Manage shellcheck version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "SHELLCHECK_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "loeffel-io/ls-lint",
      "description": "Manage ls-lint version",
      "fileMatch": [
        "^.github/.env$"
      ],
      "matchStrings": [
        "LS_LINT_VERSION=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mikefarah/yq",
      "description": "Manage yq version",
      "fileMatch": [
        "^tools/run.sh$"
      ],
      "matchStrings": [
        "yq_version=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "go-task/task",
      "description": "Manage task version",
      "fileMatch": [
        "^tools/run.sh$"
      ],
      "matchStrings": [
        "task_version=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "astral-sh/uv",
      "description": "Manage uv version",
      "fileMatch": [
        "^bin/lima.sh$"
      ],
      "matchStrings": [
        "uv_version=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "pnpm/pnpm",
      "description": "Manage pnpm version",
      "fileMatch": [
        "^bin/lima.sh$",
        "^ui/Dockerfile$"
      ],
      "matchStrings": [
        "pnpm_version=(?<currentValue>\\d+\\.\\d+\\.\\d+)",
        "PNPM_VERSION=(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "lima-vm/lima",
      "description": "Manage lima version",
      "fileMatch": [
        "^.github/actions/setup-lima/action.yaml$"
      ],
      "matchStrings": [
        "default: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ]
    }
  ],
  "extends": [
    "github>berquerant/renovate-config"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "addLabels": [
        "docker"
      ],
      "description": "Group docker dependencies",
      "groupName": "docker({{updateType}}): {{depName}}",
      "matchDatasources": [
        "docker"
      ]
    },
    {
      "addLabels": [
        "go"
      ],
      "description": "Group go dependencies",
      "groupName": "go({{updateType}}) in {{#if packageFileDir}}{{packageFileDir}}{{else}}root{{/if}}",
      "matchDatasources": [
        "go"
      ]
    }
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ]
}
